{
    // PHP Intelephense - target PHP 8.2 to match cPanel
    "intelephense.environment.phpVersion": "8.2.0",

    // Tell Intelephense where the project root is
    "intelephense.environment.documentRoot": "webroot",

    // Exclude large directories from indexing (speeds up Intelephense significantly)
    "intelephense.files.exclude": [
        "**/.git/**",
        "**/tmp/**",
        "**/logs/**",
        "**/vendors/bin/**",
        "**/vendors/cakephp_old/**",
        "**/vendors/PHPExcel/**",
        "**/webroot/js/ckeditor/**",
        "**/webroot/files/**"
    ],

    // Include CakePHP-relevant PHP stubs
    "intelephense.stubs": [
        "apache",
        "bcmath",
        "calendar",
        "core",
        "ctype",
        "curl",
        "date",
        "dom",
        "exif",
        "fileinfo",
        "filter",
        "gd",
        "hash",
        "iconv",
        "intl",
        "json",
        "mbstring",
        "mcrypt",
        "meta",
        "mysqli",
        "openssl",
        "pcre",
        "PDO",
        "pdo_mysql",
        "Phar",
        "posix",
        "readline",
        "Reflection",
        "session",
        "SimpleXML",
        "soap",
        "sockets",
        "sodium",
        "SPL",
        "standard",
        "tokenizer",
        "xml",
        "xmlreader",
        "xmlwriter",
        "zip",
        "zlib"
    ],

    // Associate .ctp (CakePHP template) files with PHP syntax highlighting
    "files.associations": {
        "*.ctp": "php"
    },

    // Exclude noisy directories from VS Code file explorer
    "files.exclude": {
        "**/tmp/cache/**": true,
        "**/logs/*.log*": true,
        "**/.git": true
    },

    // Search exclusions (speed up Ctrl+Shift+F)
    "search.exclude": {
        "**/vendors/**": true,
        "**/tmp/**": true,
        "**/logs/**": true,
        "**/webroot/js/ckeditor/**": true,
        "**/webroot/files/**": true
    },

    // Use spaces, not tabs (CakePHP coding standard)
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
        "editor.tabSize": 4
    }
}
