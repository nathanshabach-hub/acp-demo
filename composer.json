{
    "name": "cakephp/app",
    "description": "ACP portal on PHP 8.2+ and CakePHP 5",
    "homepage": "http://cakephp.org",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "cakephp/cakephp": "^5.3",
        "mobiledetect/mobiledetectlib": "^4.8",
        "cakephp/migrations": "^4.9"
    },
    "require-dev": {
        "psy/psysh": "^0.12",
        "cakephp/debug_kit": "^5.2",
        "cakephp/bake": "^3.6",
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "cakephp/cakephp-codesniffer": "Allows to check the code against the coding standards used in CakePHP."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src",
            "AkkaFacebook\\": "./plugins/AkkaFacebook/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests"
        }
    },
    "scripts": {
        "post-install-cmd": "App\\Console\\Installer::postInstall",
        "post-create-project-cmd": "App\\Console\\Installer::postInstall"
    },
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
